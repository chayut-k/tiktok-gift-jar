# ================== Server ==================
NODE_ENV=production
# PORT ตั้งโดย Railway อัตโนมัติ — ไม่ต้องใส่ก็ได้

# บน Railway ไม่ต้องใส่ก็ได้ (ระบบ detect จาก RAILWAY_STATIC_URL)
# ใส่เมื่อมี custom domain: https://your-domain.com
# APP_URL=https://your-app.up.railway.app

# ================== Security ==================
# สร้างด้วย: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string

# บน Railway ไม่ต้องใส่ก็ได้ (ใช้ APP_URL อัตโนมัติ)
# ALLOWED_ORIGINS=https://your-app.up.railway.app

# ================== Google OAuth ==================
# จาก Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ================== Data (Railway Volume) ==================
# สร้าง Volume ใน Railway แล้ว mount ที่ /data
# USERS_FILE=/data/users.json