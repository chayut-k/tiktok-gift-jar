# ================== Server ==================
NODE_ENV=production
# PORT ตั้งโดย Railway อัตโนมัติ — ไม่ต้องใส่ก็ได้

# บน Railway ไม่ต้องใส่ก็ได้ (ระบบ detect จาก RAILWAY_STATIC_URL)
# ใส่เมื่อมี custom domain: https://your-domain.com
# APP_URL=https://your-app.up.railway.app

# ================== Security ==================
# สร้างด้วย: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string

# บน Railway ไม่ต้องใส่ก็ได้ (ใช้ APP_URL อัตโนมัติ)
# ALLOWED_ORIGINS=https://your-app.up.railway.app

# ================== Google Sign-In ==================
# จาก Google Cloud Console → APIs & Services → Credentials (Web client)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
#
# Authorized JavaScript origins ต้องมีทุกโดเมนที่ใช้งาน เช่น:
#   https://your-app.up.railway.app
#   http://localhost:3000
# Authorized redirect URIs (ถ้าใช้ redirect flow): เหมือน origins ด้านบน

# ================== Data (Railway Volume) ==================
# สร้าง Volume ใน Railway แล้ว mount ที่ /data — ข้อมูลจะไม่หายเมื่อ deploy
# โค้ดจะใช้ /data อัตโนมัติถ้ามี Volume mount อยู่
# DATA_DIR=/data
# USERS_FILE=/data/users.json
# SESSION_DIR=/data/sessions

# ================== TikTok (ถ้าถูกบล็อก SIGI_STATE) ==================
# คัดลอกจาก cookies หลัง login TikTok ในเบราว์เซอร์ (เก็บเป็นความลับ)
# TIKTOK_SESSION_ID=your_sessionid_cookie
# TIKTOK_TT_TARGET_IDC=useast1a
# TIKTOK_SIGN_API_KEY=your_eulerstream_api_key